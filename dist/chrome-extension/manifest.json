{
  "manifest_version": 3,
  "name": "TORN'z Tools",
  "description": "Read-only TORN'z/FLUZ helper for Torn.",
  "version": "0.12.17",
  "version_name": "0.12.17",
  "author": "FLUZ",
  "icons": {
    "16": "icons/tornz-16.png",
    "32": "icons/tornz-32.png",
    "48": "icons/tornz-48.png",
    "128": "icons/tornz-128.png"
  },
  "action": {
    "default_title": "Open TORN'z Profile",
    "default_icon": {
      "16": "icons/tornz-16.png",
      "32": "icons/tornz-32.png",
      "48": "icons/tornz-48.png",
      "128": "icons/tornz-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.torn.com/*",
    "https://torn.com/*",
    "https://api.torn.com/*",
    "https://tornsy.com/*",
    "https://docs.google.com/*",
    "https://gitlab.com/*",
    "https://weav3r.dev/*",
    "https://yata.yt/*",
    "https://ffscouter.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.torn.com/*",
        "https://torn.com/*"
      ],
      "js": [
        "content/gm-polyfill.js",
        "content/tornz-tools.js"
      ],
      "run_at": "document_start"
    }
  ]
}
